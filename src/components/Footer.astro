---
import Dash from "./Dash.astro";
import Anchor from "./Anchor.astro";
const currentYear = new Date().getFullYear();
---

<footer class="Footer">
  <small><Anchor href="/colophon" primary="Colophon" /></small>
  <Dash isFullWidth />
  <small>© {currentYear}</small>
  &nbsp;
  <small>Cartogram Inc.</small>
</footer>

<style>
  .Footer {
    position: relative;
    display: flex;
    width: 100%;
    align-items: center;
    gap: 1px;
  }
</style>
